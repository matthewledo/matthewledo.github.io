  // Loop through holiday data and append to the right region
  function renderHolidayDay(dayKey) {
    const day = holidayDays[dayKey];
    if (!day) return;

    // Update header
    const isFrench = document.documentElement.lang === "fr";

    document.getElementById("holiday-text").innerHTML = `
  <h1> ${isFrench ? "Heures de jour férié" : "Holiday Hours"} </h1>
  <h2> ${isFrench ? day.labelFR : day.labelEN} </h2>
`;

    // Clear all regions
    Object.values(regionMap).forEach((region) => {
      region
        .querySelectorAll(".holiday-hours:not(.top-row)")
        .forEach((el) => el.remove());
    });

    // Render selected day
    day.hours.forEach(({ store, region, hours }) => {
      const hoursFR = convertToFrenchHours(hours);

      const div = document.createElement("div");
      div.className = "holiday-hours";
      div.innerHTML = `
      <div class="store">${store}</div>
      <div class="hours">${isFrench ? hoursFR : hours}</div>
    `;
      regionMap[region]?.appendChild(div);
    });
  }

  function convertToFrenchHours(enHours) {
    if (!enHours) return "";
    const trimmed = enHours.trim().toUpperCase();

    if (hourMap[trimmed]) {
      return hourMap[trimmed];
    }

    const parts = trimmed.split(/\s*-\s*/);
    if (parts.length === 2) {
      const start = hourMap[parts[0]];
      const end = hourMap[parts[1]];
      if (start && end) {
        return `${start} - ${end}`;
      }
    }

    return enHours;
  }

  document.querySelector(".panel-heading a").addEventListener("click", function (e) {
    var clickedHeader = this.closest(".panel").querySelector(".panel-collapse");

    if (clickedHeader.classList.contains("in")) {
      e.stopPropagation();
      clickedHeader.classList.remove("in");

    }
  });

  const todayISO = new Date().toISOString().split("T")[0];
  const defaultDay = "2025-12-23";

  const initialDay = document.querySelector(
    `#holiday-day-nav button[data-day="${todayISO}"]`,
  )
    ? todayISO
    : defaultDay;

  document.querySelectorAll("#holiday-day-nav button").forEach((btn) => {
    btn.addEventListener("click", () => {
      document
        .querySelectorAll("#holiday-day-nav button")
        .forEach((b) => b.classList.remove("active"));

      btn.classList.add("active");
      renderHolidayDay(btn.dataset.day);
    });
  });

  document.querySelector(".panel-heading").addEventListener("click", function (e) {
    this.querySelector(".panel-title a").click();
  });
  window.addEventListener("load", () => {
    document.querySelector("#custom-page-loader").style.display = "none";
    document.querySelector("#loader-wrap").style.display = "none";
    document.querySelector("#holiday-hours-page-content").classList.add("visible");

    const initialBtn = document.querySelector(
      `#holiday-day-nav button[data-day="${initialDay}"]`,
    );

    if (initialBtn) {
      initialBtn.classList.add("active");
      renderHolidayDay(initialDay);
    }
  });
