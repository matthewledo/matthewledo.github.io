<style>
  .page_content .col-sm-12 {
    padding: 0px;
  }

  #content .container {
    max-width: 2000px;
    width: 100% !important;
  }

  #content #breadcrumbContainer,
  #content .container .title {
    display: none;
  }

  #content .sfbox,
  #content .rte {
    box-shadow: none;
    border-radius: 0;
    padding: 0;
  }

  /* loader */

  #custom-page-loader {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 1;
    margin: -50px 0 0 -50px;
    border: 10px solid #f3f3f3;
    border-radius: 50%;
    border-top: 10px solid #ffef00;
    width: 100px;
    height: 100px;
    -webkit-animation: spin 2s linear infinite;
    animation: spin 2s linear infinite;
  }

  @-webkit-keyframes spin {
    0% {
      -webkit-transform: rotate(0deg);
    }
    100% {
      -webkit-transform: rotate(360deg);
    }
  }

  @keyframes spin {
    0% {
      transform: rotate(0deg);
    }
    100% {
      transform: rotate(360deg);
    }
  }
  #holiday-hours-page-content {
    opacity: 0;
    transition: opacity 0.1s ease-in-out;
  }
  #holiday-hours-page-content.visible {
    opacity: 1 !important;
    transition: opacity 0.1s ease-in-out;
  }

  .holiday-hours {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row;
    align-items: center;
    border-bottom: solid #eee 1px;
    color: #333;
    font-size: 16px;
    text-align: center;
  }

  .holiday-hours:hover {
    font-weight: bold;
  }

  .holiday-hours .bold {
    font-weight: bold;
  }

  .holiday-hours .store {
    width: 36%;
    padding: 3px;
    text-align: left;
  }

  .holiday-hours .hours {
    width: 64%;
    padding: 3px;
  }

  #content #breadcrumbContainer,
  #content .container .title {
    display: none;
  }

  #content .container {
    width: 100%;
  }

  #content .container .col-sm-12 {
    padding: 0px;
  }

  #holiday-banner {
    position: relative;

    /* Family Day */
    /* background-image: url(https://cdn.shopify.com/s/files/1/2660/5106/files/purple-balloons-on-the-left-side_KRAKEN.jpg?v=1581542250); */

    /* Easter */
    /* background-image: url(https://cdn.shopify.com/s/files/1/2660/5106/files/easter-eggs-and-ears-wood-kraken.progressive.jpg); */

    /* Victoria Day */
    /* background-image: url(https://cdn.shopify.com/s/files/1/2660/5106/files/Holiday-Hours-Background.jpg?44774); */

    /* background-image: url(https://cdn.shopify.com/s/files/1/2660/5106/files/canada-day-holiday-hours.jpg); */

    /* Thanksgiving */
    /* background-image: url(https://cdn.shopify.com/s/files/1/2660/5106/files/timothy-eberly-yuiJO6bvHi4-unsplash.jpg?v=1633528514); */

    /* Christmas */
    background-image: url(https://cdn.shopify.com/s/files/1/2660/5106/files/xmas-holidays.webp?v=1766433859);

    /* height: 200px; */
    height: 280px;
    max-width: 2000px;
    /* background-attachment: fixed;
    background-position: center; */
    background-position: 49% 36%;
    background-repeat: no-repeat;
    background-size: cover;
    margin: 0 auto 15px auto;
  }

  #holiday-banner #holiday-overlay {
    position: absolute;
    top: 0%;
    left: 0%;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.1);
  }

  #holiday-banner #holiday-text {
    position: absolute;
    top: 50%;
    width: 100%;
    transform: translateY(-50%);
    text-align: center;
    padding: 0px 15px;
  }

  #holiday-banner #holiday-text h1 {
    color: white;
    /* font-size: calc(37px + (40 - 20) * ((100vw - 320px) / 680)); */
    font-size: calc(32px + (37 - 20) * ((100vw - 320px) / 680));
    text-shadow: 4px 4px 5px #000;
    margin-bottom: 20px;
  }

  #holiday-banner #holiday-text h2 {
    color: white;
    /* font-size: 25px; */
    text-shadow: 4px 4px 5px #000;
    font-size: calc(20px + (25 - 20) * ((100vw - 320px) / 680));
  }

  .panel-heading {
    cursor: pointer;
  }

  .panel-group .panel-title a {
    color: #333;
  }

  .panel-body .holiday-hours:nth-child(even) {
    background-color: #d4d4d42b;
    border-bottom: solid #82828226 2px;
    border-top: solid #82828226 2px;
  }
  .holiday-hours {
    padding: 2px;
  }
  #holiday-day-nav {
    display: flex;
    gap: 0.75rem;
    overflow-x: auto;
    border-bottom: 1px solid #e5e5e5;
    padding-bottom: 3rem;
    margin-bottom: 2rem;
    scrollbar-width: thin; /* Firefox */
  }
  #holiday-day-nav button {
    flex: 1 1 0;
    min-width: 90px;
    padding: 0.6rem 0.9rem;
    text-align: center;
    font-size: 18px;
    /* flex-basis: 12%; */
    padding: 0.5rem 0.9rem;
    border-radius: 999px;
    font-weight: 600;
    white-space: nowrap;
    background: #f7f7f7;
    border: 1px solid #d0d0d0;
    color: #222;
  }
  #holiday-day-nav button.active {
    background: #000;
    color: #fff;
    border-color: #000;
  }
  #holiday-day-nav button:not(.active):hover {
    background: #eee;
  }
  #holiday-day-nav button.today::after {
    content: "•";
    margin-left: 4px;
  }
  @media (min-width: 2000px) {
    #holiday-banner #holiday-text h1 {
      font-size: 65px;
    }
  }
  @media (max-width: 1024px) {
    #holiday-banner {
      background-attachment: initial;
      background-position: center;
    }
  }
  @media (max-width: 420px) {
    #holiday-banner #holiday-text h1 {
      font-size: calc(37px + (37 - 20) * ((100vw - 320px) / 680));
    }
  }
</style>
