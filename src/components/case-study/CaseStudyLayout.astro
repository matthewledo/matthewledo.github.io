---
import Layout from "../../layouts/Layout.astro";
import ProjectActions from '../../components/ProjectActions.jsx'; // Import the React component
import { HiArrowLeft, HiExternalLink, HiCode } from "react-icons/hi";

interface Props {
  project: {
    title: string;
    description: string;
    heroImage?: string;
    image?: string;
    challenge: string;
    solution: string;
    technologies: string[];
    techStack: string;
    results: string[];
    role: string;
    client: string;
    timeline: string;
    demo?: string;
    code?: string;
    // Add optional properties for your modal/video component
    videoTitle?: string;
    videoSrc?: string;
    sourceImages?: Array<{ src: string; caption: string }>;
  };
}

const { project } = Astro.props;
---

<Layout title={`${project.title} | Case Study`} description={project.description}>
  <div class="bg-slate-50 border-b border-slate-200 pt-32 pb-20 px-6">
    <div class="max-w-7xl mx-auto">
      <a href="/projects" class="inline-flex items-center gap-2 text-sm font-bold text-slate-500 hover:text-emerald-600 mb-8 transition-colors">
        <HiArrowLeft /> Back to Projects
      </a>
      
      <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 tracking-tight mb-6">
        {project.title}
      </h1>
      
      <p class="text-xl text-slate-600 max-w-3xl leading-relaxed">
        {project.description}
      </p>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 lg:grid-cols-3 gap-12">
    
    <div class="lg:col-span-2 space-y-16">
      <div class="rounded-2xl overflow-hidden border border-slate-200 shadow-sm bg-[linear-gradient(135deg,#0f172a_60%,#059669)]">
        <img 
          src={project.heroImage || project.image} 
          alt={project.title} 
          class="w-full h-auto object-cover"
        />
      </div>

      <section>
        <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-3">
          <span class="w-8 h-1 bg-emerald-500 rounded-full"></span>
          The Challenge
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed">
          {project.challenge}
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-slate-900 mb-4 flex items-center gap-3">
          <span class="w-8 h-1 bg-emerald-500 rounded-full"></span>
          The Solution
        </h2>
        <p class="text-slate-600 text-lg leading-relaxed mb-6">
          {project.solution}
        </p>
        
        <div class="flex flex-wrap gap-2">
          {project.technologies.map((tech) => (
            <span class="px-3 py-1 bg-slate-100 text-slate-700 text-sm font-medium rounded-md border border-slate-200">
              {tech}
            </span>
          ))}
        </div>
      </section>

      <section class="bg-emerald-50/50 rounded-2xl p-8 border border-emerald-100">
        <h2 class="text-2xl font-bold text-emerald-800 mb-6">Key Outcomes</h2>
        <ul class="space-y-4">
          {project.results.map((result) => (
            <li class="flex items-start gap-3 text-slate-700">
              <span class="mt-1.5 w-2 h-2 bg-emerald-500 rounded-full shrink-0"></span>
              <span class="font-medium">{result}</span>
            </li>
          ))}
        </ul>
      </section>
    </div>

    <aside class="lg:col-span-1">
      <div class="sticky top-24 bg-white rounded-2xl border border-slate-200 p-6 shadow-sm">
        <h3 class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-6">Project Info</h3>
        
        <div class="space-y-6">
          <div>
            <span class="block text-sm text-slate-500 mb-1">Role</span>
            <span class="block font-bold text-slate-900">{project.role}</span>
          </div>

                           <div>
            <span class="block text-sm text-slate-500 mb-1">Tech Stack</span>
            <span class="block font-bold text-slate-900">{project.techStack}</span>
          </div>
          
          <div>
            <span class="block text-sm text-slate-500 mb-1">Client</span>
            <span class="block font-bold text-slate-900">{project.client}</span>
          </div>
          
          <div>
            <span class="block text-sm text-slate-500 mb-1">Timeline</span>
            <span class="block font-bold text-slate-900">{project.timeline}</span>
          </div>

          <hr class="border-slate-100" />

          <div class="flex flex-col gap-3">
            {/* CONDITIONAL RENDERING LOGIC HERE */}
            {project.videoSrc || project.sourceImages ? (
              <ProjectActions 
                client:load 
                videoTitle={project.videoTitle}
                videoSrc={project.videoSrc} 
                sourceImages={project.sourceImages} 
              />
            ) : (
              <>
                {project.demo && (
                  <a 
                    href={project.demo} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="flex items-center justify-center gap-2 w-full py-3 bg-slate-900 text-white font-bold rounded-xl hover:bg-emerald-600 transition-colors"
                  >
                    <HiExternalLink /> Live Demo
                  </a>
                )}
                
                {project.code && (
                  <a 
                    href={project.code}
                    target="_blank" 
                    rel="noopener noreferrer" 
                    class="flex items-center justify-center gap-2 w-full py-3 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:border-slate-900 transition-colors"
                  >
                    <HiCode /> View Code
                  </a>
                )}
              </>
            )}
          </div>
        </div>
      </div>
    </aside>

  </main>
</Layout>